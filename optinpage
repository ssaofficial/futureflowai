<script>
  // Waveform bars
  function generateWaveform(id) {
    const el = document.getElementById(id + '-wave');
    if (!el) return;
    const h = [30,55,70,45,80,60,35,75,50,65,40,85,55,45,70,60,35,80,50,65,45,75,55,40,70];
    el.innerHTML = h.map(v => `<div class="waveform-bar" style="height:${v}%"></div>`).join('');
  }
  ['r1a','r1b','r1c','r2a','r2b','r2c','r3a','r3b','r3c'].forEach(generateWaveform);

  // Audio
  let curCard = null, curAudio = null;
  function toggleAudio(id, card) {
    const audio = document.getElementById('audio-' + id);
    if (curCard && curCard !== card) { curCard.classList.remove('playing'); if (curAudio) { curAudio.pause(); curAudio.currentTime = 0; } }
    if (card.classList.contains('playing')) {
      card.classList.remove('playing'); if (audio) audio.pause(); curCard = null; curAudio = null;
    } else {
      card.classList.add('playing'); curCard = card; curAudio = audio;
      if (audio) {
        audio.play().catch(() => { card.classList.remove('playing'); });
        audio.onended = () => { card.classList.remove('playing'); curCard = null; curAudio = null; };
      }
    }
  }

  // FAQ
  function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const ans = item.querySelector('.faq-answer');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => { el.classList.remove('open'); el.querySelector('.faq-answer').style.maxHeight = null; });
    if (!isOpen) { item.classList.add('open'); ans.style.maxHeight = ans.scrollHeight + 'px'; }
  }

  // Scroll reveal
  const revEls = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });
  revEls.forEach(el => obs.observe(el));

  // Sticky
  const stickyCta = document.getElementById('sticky-cta');
  window.addEventListener('scroll', () => {
    if (window.innerWidth <= 700) stickyCta.style.display = window.scrollY > 400 ? 'flex' : 'none';
  });
</script>
